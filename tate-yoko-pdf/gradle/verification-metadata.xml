<?xml version="1.0" encoding="UTF-8"?>
<!--
  Dependency verification metadata.

  Scope: this file currently only pins the qpdf release binaries that we
  download via the Ivy URL repo declared in build.gradle.kts. Maven Central
  artifacts are explicitly trusted by the regex below so introducing this file
  does not require seeding hashes for the entire Gradle graph (which would
  add a substantial maintenance burden for limited security gain — Maven
  Central already provides signature-backed provenance).

  Verifying qpdf bytes IS valuable because we fetch them straight from a
  GitHub releases CDN over HTTPS, with no PGP/sigstore signature pipeline.
  The pinned SHA-256 hashes were verified by hand against the release page.
-->
<verification-metadata xmlns="https://schema.gradle.org/dependency-verification" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://schema.gradle.org/dependency-verification https://schema.gradle.org/dependency-verification/dependency-verification-1.3.xsd">
  <configuration>
    <verify-metadata>false</verify-metadata>
    <verify-signatures>false</verify-signatures>
    <trusted-artifacts>
      <trust group="^(?!com\.github\.qpdf$).*" regex="true"/>
    </trusted-artifacts>
  </configuration>
  <components>
    <component group="com.github.qpdf" name="qpdf" version="12.3.2">
      <artifact name="qpdf-12.3.2-bin-linux-x86_64.zip">
        <sha256 value="44f2c53bf784c0143128d80d2b9946e9793962c5bb403b75c0024cb4d8e346b9" origin="Verified manually against https://github.com/qpdf/qpdf/releases/tag/v12.3.2"/>
      </artifact>
      <artifact name="qpdf-12.3.2-mingw64.zip">
        <sha256 value="ebeb4692434a8cb8a27f876584c0c2b402b6251dc6c8ed4b39cf2304cada10e0" origin="Verified manually against https://github.com/qpdf/qpdf/releases/tag/v12.3.2"/>
      </artifact>
    </component>
  </components>
</verification-metadata>
