root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.{md,markdown}]
trim_trailing_whitespace = false

# The web/data family is 2-space: Biome formats js/ts/json at 2, Prettier formats svelte/css at 2.
[*.{json,jsonc,toml,yaml,yml,ts,js,mjs,svelte,css}]
indent_size = 2

[justfile]
indent_size = 4
