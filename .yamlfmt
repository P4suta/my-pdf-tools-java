formatter:
  type: basic
  indent: 2
  retain_line_breaks_single: true
  scan_folded_as_literal: true
  trim_trailing_whitespace: true
  eof_newline: true
  line_ending: lf
  pad_line_comments: 1
  max_line_length: 0

include:
  - "**/*.yml"
  - "**/*.yaml"

exclude:
  - "**/build/**"
  - "**/.gradle/**"
  - "**/.gradle-home/**"
  - "**/artifacts/**"
  # The SPA's vendored deps and pnpm's own generated files are not ours to reformat. node_modules
  # also holds pnpm dot-files/dot-dirs (.modules.yaml, .pnpm/) that a plain **/node_modules/** glob
  # skips (globs don't match dotted segments), so list those explicitly too.
  - "**/node_modules/**"
  - "**/.modules.yaml"
  - "**/.pnpm/**"
  - "**/pnpm-lock.yaml"
